# MCP Server — stdio protocol handler
#
# Content-Length framed stdio protocol with JSON Lines auto-detection.

use src.util.json_helpers.{js, jp, jo1, jo2, jo3, make_json_result, make_error, safe_substr, extract_field, extract_field_raw, extract_id, extract_nested, extract_arg, tool_text_result, LB, RB}
use src.mcp.tools.{make_tools_list}
use src.mcp.handlers.{handle_tool_call}
use src.core.indexer.{IndexDb, open_index_db, open_index_memory, close_index_db, create_schema}

extern fn rt_env_get(name: text) -> text

# --- Constants ---

val SERVER_NAME = "obsidian-search"
val SERVER_VERSION = "0.1.0"
val NL = "\n"

# --- Protocol state ---

var USE_JSON_LINES = false

# --- Protocol I/O ---

fn read_stdin_message() -> text:
    var line = input()
    if line == "":
        return ""
    if line.ends_with("\r"):
        line = safe_substr(line, 0, line.len() - 1)
    if line.starts_with(LB()):
        USE_JSON_LINES = true
        return line
    if line.starts_with("Content-Length:"):
        var len_str = line.replace("Content-Length:", "")
        len_str = len_str.trim()
        val content_length = int(len_str) ?? 0
        if content_length == 0:
            return ""
        input()
        var body = input(content_length)
        return body
    ""

fn write_stdout_message(body: text):
    if USE_JSON_LINES:
        print_raw(body + NL)
    else:
        val byte_count = body.len()
        var header = "Content-Length: " + str(byte_count) + "\r" + NL + "\r" + NL
        print_raw(header)
        print_raw(body)

# --- Initialize response ---

fn make_init_response(id: text) -> text:
    val tools_cap = jo1(jp("listChanged", "false"))
    val caps = jo1(jp("tools", tools_cap))
    val server_info = jo3(
        jp("name", js(SERVER_NAME)),
        jp("version", js(SERVER_VERSION)),
        jp("instructions", js("Obsidian vault search MCP server with hybrid text/graph ranking. Set OBSIDIAN_VAULT_PATH to your vault directory."))
    )
    val result = jo3(
        jp("protocolVersion", js("2024-11-05")),
        jp("capabilities", caps),
        jp("serverInfo", server_info)
    )
    make_json_result(id, result)

# --- Server loop ---

fn start_server():
    val vault_path = rt_env_get("OBSIDIAN_VAULT_PATH") ?? ""

    var db = open_index_memory()
    create_schema(db)

    var running = true
    while running:
        var line = read_stdin_message()
        if line == "":
            running = false
        else:
            var method = extract_field(line, "method")
            var id = extract_id(line)
            var response = ""
            if method == "initialize":
                response = make_init_response(id)
            elif method == "initialized" or method == "notifications/initialized":
                response = ""
            elif method == "notifications/cancelled" or method == "notifications/roots/list_changed":
                response = ""
            elif method == "shutdown":
                response = make_json_result(id, "null")
            elif method == "ping":
                response = make_json_result(id, LB() + RB())
            elif method == "tools/list":
                response = make_tools_list(id)
            elif method == "tools/call":
                response = handle_tool_call(id, line, db, vault_path)
            else:
                if id != "" and id != "null":
                    response = make_error(id, -32601, "Method not found: " + method)
            if response != "":
                write_stdout_message(response)

    close_index_db(db)
