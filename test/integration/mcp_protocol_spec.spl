describe "Error Handling":
    """Tests for error responses"""

    context "unknown tool":
        it "returns error for nonexistent tool":
            val db = setup_test_db()
            val body = make_tool_request("99", "nonexistent_tool", jo1(jp("x", js("y"))))
            val response = handle_tool_call("99", body, db, "")
            expect(response).to_contain("Unknown tool")
            expect(response).to_contain("-32602")
            close_index_db(db)

    context "missing required params":
        it "read_note requires path":
            val db = setup_test_db()
            val body = make_tool_request("1", "read_note", LB() + RB())
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

        it "find_backlinks requires note_path":
            val db = setup_test_db()
            val body = make_tool_request("1", "find_backlinks", LB() + RB())
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

        it "graph_walk requires seed":
            val db = setup_test_db()
            val body = make_tool_request("1", "graph_walk", LB() + RB())
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

        it "search_by_tag requires tag":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_by_tag", LB() + RB())
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

        it "find_forward_links requires note_path":
            val db = setup_test_db()
            val body = make_tool_request("1", "find_forward_links", LB() + RB())
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

        it "find_related requires note_path":
            val db = setup_test_db()
            val body = make_tool_request("1", "find_related", LB() + RB())
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

# ============================================================================
# Test Group 9: Edge Cases
# ============================================================================

describe "Edge Cases":
    """Tests for edge cases in protocol and JSON handling"""

    context "special characters in search queries":
        it "handles quotes in query":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_vault", jo1(jp("query", js("say \\\"hello\\\""))))
            val response = handle_tool_call("1", body, db, "")
            # Should not crash — may return empty results
            expect(response).to_contain("result")
            close_index_db(db)

        it "handles empty query":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_vault", jo1(jp("query", js(""))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

    context "limit edge cases":
        it "handles zero limit in search_vault":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_vault", jo2(jp("query", js("Alpha")), jp("limit", js("0"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

        it "handles negative limit":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_vault", jo2(jp("query", js("Alpha")), jp("limit", js("-5"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

        it "handles very large limit":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_vault", jo2(jp("query", js("Alpha")), jp("limit", js("999"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

    context "graph_walk edge cases":
        it "handles zero hops":
            val db = setup_test_db()
            val body = make_tool_request("1", "graph_walk", jo2(jp("seed", js("alpha.md")), jp("hops", js("0"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("nodes")
            close_index_db(db)

        it "handles negative hops":
            val db = setup_test_db()
            val body = make_tool_request("1", "graph_walk", jo2(jp("seed", js("alpha.md")), jp("hops", js("-1"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("nodes")
            close_index_db(db)

    context "JSON-RPC response format invariants":
        it "all results contain jsonrpc 2.0":
            val db = setup_test_db()
            val body1 = make_tool_request("1", "search_vault", jo1(jp("query", js("Alpha"))))
            val r1 = handle_tool_call("1", body1, db, "")
            expect(r1).to_contain("\"jsonrpc\":\"2.0\"")
            val body2 = make_tool_request("2", "nonexistent", jo1(jp("x", js("y"))))
            val r2 = handle_tool_call("2", body2, db, "")
            expect(r2).to_contain("\"jsonrpc\":\"2.0\"")
            close_index_db(db)

        it "all results contain matching id":
            val db = setup_test_db()
            val body = make_tool_request("77", "search_vault", jo1(jp("query", js("Alpha"))))
            val response = handle_tool_call("77", body, db, "")
            expect(response).to_contain("\"id\":77")
            close_index_db(db)

    context "multiple operations on same db":
        it "supports sequential tool calls":
            val db = setup_test_db()
            val body1 = make_tool_request("1", "search_vault", jo1(jp("query", js("Alpha"))))
            val r1 = handle_tool_call("1", body1, db, "")
            expect(r1).to_contain("Alpha")
            val body2 = make_tool_request("2", "search_by_tag", jo1(jp("tag", js("reference"))))
            val r2 = handle_tool_call("2", body2, db, "")
            expect(r2).to_contain("Beta")
            val body3 = make_tool_request("3", "find_backlinks", jo1(jp("note_path", js("beta.md"))))
            val r3 = handle_tool_call("3", body3, db, "")
            expect(r3).to_contain("result")
            close_index_db(db)

    context "empty database":
        it "search_vault returns empty results":
            val db = open_index_memory()
            create_schema(db)
            val body = make_tool_request("1", "search_vault", jo1(jp("query", js("anything"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("count")
            expect(response).to_contain("result")
            close_index_db(db)

        it "search_by_tag returns empty results":
            val db = open_index_memory()
            create_schema(db)
            val body = make_tool_request("1", "search_by_tag", jo1(jp("tag", js("anything"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("count")
            expect(response).to_contain("result")
            close_index_db(db)
