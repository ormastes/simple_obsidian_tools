# Integration test — MCP protocol I/O, initialization, and dispatch
#
# Intensive tests for the MCP server protocol layer covering:
# - JSON-RPC response format
# - Protocol version negotiation
# - Initialize handshake
# - tools/list completeness
# - Content-Length framing output
# - Error responses for unknown methods
# - Edge cases in JSON field extraction
# - All tool dispatch coverage

use src.util.json_helpers.{js, jp, jo1, jo2, jo3, ja, jo, ji, jb, jnull, jf, jo0, extract_field, extract_field_raw, extract_id, extract_nested, extract_arg, make_json_result, make_error, tool_text_result, safe_substr, escape_json, LB, RB, SB_L, SB_R, Q}
use src.core.indexer.{IndexDb, open_index_memory, close_index_db, create_schema, index_note, note_count}
use src.mcp.handlers.{handle_tool_call}
use src.mcp.tools.{make_tools_list}

# --- Helpers ---

fn make_request(id: text, method: text, params_json: text) -> text:
    var body = LB()
    body = body + jp("jsonrpc", js("2.0"))
    body = body + "," + jp("id", id)
    body = body + "," + jp("method", js(method))
    if params_json != "":
        body = body + "," + jp("params", params_json)
    body = body + RB()
    body

fn make_tool_request(id: text, tool_name: text, args_json: text) -> text:
    var body = LB()
    body = body + jp("jsonrpc", js("2.0"))
    body = body + "," + jp("id", id)
    body = body + "," + jp("method", js("tools/call"))
    body = body + "," + jp("params", jo2(
        jp("name", js(tool_name)),
        jp("arguments", args_json)
    ))
    body = body + RB()
    body

fn setup_test_db() -> IndexDb:
    val db = open_index_memory()
    create_schema(db)
    index_note(db, "/v/alpha.md", "alpha.md", "---\ntitle: Alpha Note\naliases: [a-note]\ntags: [project, active]\n---\n\n# Alpha\n\nMain content about [[beta]] and search.\n\n## Tasks\n- [ ] Open task one\n- [x] Done task two\n- [ ] Another open task\n\n## Decision\nWe decided to use FTS5.", 1000)
    index_note(db, "/v/beta.md", "beta.md", "---\ntitle: Beta Note\ntags: [reference, docs]\n---\n\n# Beta\n\nLinked from [[alpha]]. Reference material.\n\nContains keywords: ranking, search, BM25.", 1000)
    index_note(db, "/v/gamma.md", "gamma.md", "---\ntitle: Gamma Note\ntags: [project, archived]\n---\n\n# Gamma\n\nArchived project. Links to [[alpha]] and [[beta]].\n\n## Tasks\n- [x] All tasks completed", 1000)
    db

# ============================================================================
# Test Group 1: JSON Helper Functions
# ============================================================================

describe "JSON Helpers":
    """Unit tests for JSON construction and extraction utilities"""

    context "value constructors":
        it "builds string values with proper quoting":
            expect(js("hello")).to_equal("\"hello\"")

        it "builds integer values":
            expect(ji(42)).to_equal("42")
            expect(ji(-1)).to_equal("-1")
            expect(ji(0)).to_equal("0")

        it "builds boolean values":
            expect(jb(true)).to_equal("true")
            expect(jb(false)).to_equal("false")

        it "builds null":
            expect(jnull()).to_equal("null")

    context "JSON escaping":
        it "escapes double quotes":
            val result = escape_json("say \"hello\"")
            expect(result).to_contain("\\\"")

        it "escapes backslashes":
            val result = escape_json("path\\to\\file")
            expect(result).to_contain("\\\\")

        it "escapes newlines":
            val result = escape_json("line1\nline2")
            expect(result).to_contain("\\n")

        it "escapes tabs":
            val result = escape_json("col1\tcol2")
            expect(result).to_contain("\\t")

        it "handles empty string":
            expect(escape_json("")).to_equal("")

        it "handles string with no special chars":
            expect(escape_json("plain text")).to_equal("plain text")

    context "object constructors":
        it "builds empty object":
            expect(jo0()).to_equal("{}")

        it "builds single-pair object":
            val result = jo1(jp("key", js("val")))
            expect(result).to_equal("{\"key\":\"val\"}")

        it "builds two-pair object":
            val result = jo2(jp("a", "1"), jp("b", "2"))
            expect(result).to_equal("{\"a\":1,\"b\":2}")

        it "builds three-pair object":
            val result = jo3(jp("a", "1"), jp("b", "2"), jp("c", "3"))
            expect(result).to_contain("\"a\":1")
            expect(result).to_contain("\"c\":3")

    context "array constructor":
        it "builds JSON array from list":
            val items = [js("x"), js("y")]
            val result = ja(items)
            expect(result).to_equal("[\"x\",\"y\"]")

        it "builds empty array":
            val items = ["placeholder"]
            items.clear()
            val result = ja(items)
            expect(result).to_equal("[]")

    context "dynamic object constructor":
        it "builds object from pairs list":
            val pairs = [jp("x", "1"), jp("y", "2")]
            val result = jo(pairs)
            expect(result).to_equal("{\"x\":1,\"y\":2}")

    context "field extraction":
        it "extracts string field":
            val json = "{\"name\":\"Alice\",\"age\":30}"
            expect(extract_field(json, "name")).to_equal("Alice")

        it "extracts numeric field":
            val json = "{\"count\":42,\"name\":\"test\"}"
            expect(extract_field(json, "count")).to_equal("42")

        it "returns empty for missing field":
            val json = "{\"name\":\"Alice\"}"
            expect(extract_field(json, "missing")).to_equal("")

        it "extracts field from complex JSON":
            val json = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\"}"
            expect(extract_field(json, "method")).to_equal("initialize")
            expect(extract_field(json, "jsonrpc")).to_equal("2.0")

        it "extracts boolean field":
            val json = "{\"enabled\":true,\"disabled\":false}"
            expect(extract_field(json, "enabled")).to_equal("true")
            expect(extract_field(json, "disabled")).to_equal("false")

    context "extract_id":
        it "extracts numeric id":
            val json = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"test\"}"
            expect(extract_id(json)).to_equal("1")

        it "extracts string id":
            val json = "{\"jsonrpc\":\"2.0\",\"id\":\"abc\",\"method\":\"test\"}"
            expect(extract_id(json)).to_equal("\"abc\"")

        it "returns null for missing id":
            val json = "{\"jsonrpc\":\"2.0\",\"method\":\"test\"}"
            expect(extract_id(json)).to_equal("null")

    context "extract_nested":
        it "extracts field from params":
            val json = "{\"method\":\"init\",\"params\":{\"name\":\"test\",\"version\":\"1.0\"}}"
            expect(extract_nested(json, "name")).to_equal("test")
            expect(extract_nested(json, "version")).to_equal("1.0")

        it "returns empty when params missing":
            val json = "{\"method\":\"init\"}"
            expect(extract_nested(json, "name")).to_equal("")

    context "extract_arg":
        it "extracts argument from arguments object":
            val json = "{\"params\":{\"name\":\"tool\",\"arguments\":{\"query\":\"search term\",\"limit\":\"10\"}}}"
            expect(extract_arg(json, "query")).to_equal("search term")
            expect(extract_arg(json, "limit")).to_equal("10")

        it "returns empty when arguments missing":
            val json = "{\"params\":{\"name\":\"tool\"}}"
            expect(extract_arg(json, "query")).to_equal("")

    context "safe_substr":
        it "extracts substring":
            expect(safe_substr("hello world", 0, 5)).to_equal("hello")

        it "handles start offset":
            expect(safe_substr("hello world", 6, 11)).to_equal("world")

        it "handles empty result":
            expect(safe_substr("hello", 5, 5)).to_equal("")

        it "handles beyond length":
            expect(safe_substr("hi", 0, 10)).to_equal("hi")

# ============================================================================
# Test Group 2: JSON-RPC Response Builders
# ============================================================================

describe "JSON-RPC Responses":
    """Tests for JSON-RPC response formatting"""

    context "make_json_result":
        it "builds valid result response":
            val result = make_json_result("1", js("ok"))
            expect(result).to_contain("\"jsonrpc\":\"2.0\"")
            expect(result).to_contain("\"id\":1")
            expect(result).to_contain("\"result\":\"ok\"")

        it "uses correct id format":
            val result = make_json_result("42", "null")
            expect(result).to_contain("\"id\":42")

    context "make_error":
        it "builds error response with code and message":
            val result = make_error("1", -32601, "Method not found")
            expect(result).to_contain("\"error\"")
            expect(result).to_contain("\"code\":-32601")
            expect(result).to_contain("Method not found")

        it "uses standard JSON-RPC error codes":
            val parse_err = make_error("1", -32700, "Parse error")
            expect(parse_err).to_contain("-32700")
            val method_err = make_error("2", -32601, "Method not found")
            expect(method_err).to_contain("-32601")
            val param_err = make_error("3", -32602, "Invalid params")
            expect(param_err).to_contain("-32602")

    context "tool_text_result":
        it "wraps output in content array with text type":
            val result = tool_text_result("1", "{\"data\":\"test\"}")
            expect(result).to_contain("\"type\":\"text\"")
            expect(result).to_contain("\"content\"")
            expect(result).to_contain("\"result\"")

# ============================================================================
# Test Group 3: Protocol Initialization
# ============================================================================

describe "MCP Initialize":
    """Tests for MCP protocol initialization handshake"""

    context "protocol version":
        it "uses standard MCP protocol version 2024-11-05":
            # Simulate init response by checking the JSON output
            val init_json = make_request("1", "initialize", jo2(
                jp("protocolVersion", js("2024-11-05")),
                jp("clientInfo", jo2(jp("name", js("test")), jp("version", js("1.0"))))
            ))
            expect(extract_field(init_json, "method")).to_equal("initialize")

    context "server capabilities":
        it "advertises tool capabilities":
            # Build what the server would return
            val tools_cap = jo1(jp("listChanged", "false"))
            val caps = jo1(jp("tools", tools_cap))
            expect(caps).to_contain("\"tools\"")
            expect(caps).to_contain("\"listChanged\"")

# ============================================================================
# Test Group 4: Tools List
# ============================================================================

describe "MCP Tools List":
    """Tests for tools/list response completeness"""

    context "tool count":
        it "contains all 11 tools":
            val response = make_tools_list("1")
            # Phase 1: Foundation (4 tools)
            expect(response).to_contain("search_vault")
            expect(response).to_contain("read_note")
            expect(response).to_contain("search_by_tag")
            expect(response).to_contain("find_backlinks")
            # Phase 2: Graph + Ranking (4 tools)
            expect(response).to_contain("find_forward_links")
            expect(response).to_contain("find_related")
            expect(response).to_contain("find_authoritative_docs")
            expect(response).to_contain("graph_walk")
            # Phase 3: Specialized (3 tools)
            expect(response).to_contain("search_tasks")
            expect(response).to_contain("search_decisions")
            expect(response).to_contain("explain_search")

    context "tool schema format":
        it "has valid JSON-RPC result wrapper":
            val response = make_tools_list("42")
            expect(response).to_contain("\"jsonrpc\":\"2.0\"")
            expect(response).to_contain("\"id\":42")
            expect(response).to_contain("\"result\"")

        it "contains tools array in result":
            val response = make_tools_list("1")
            expect(response).to_contain("\"tools\"")

        it "each tool has name and description":
            val response = make_tools_list("1")
            # Check a few tools have inputSchema
            expect(response).to_contain("\"inputSchema\"")
            expect(response).to_contain("\"description\"")

# ============================================================================
# Test Group 5: Tool Dispatch — Phase 1 Foundation
# ============================================================================

describe "Tool Dispatch Foundation":
    """Tests for Phase 1 tool dispatch: search, read, tag, backlinks"""

    context "search_vault":
        it "returns results matching query":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_vault", jo1(jp("query", js("Alpha"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("Alpha")
            expect(response).to_contain("result")
            close_index_db(db)

        it "returns empty results for no match":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_vault", jo1(jp("query", js("zzzznonexistent"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("count")
            expect(response).to_contain("result")
            close_index_db(db)

        it "respects limit parameter":
            val db = setup_test_db()
            val body = make_tool_request("1", "search_vault", jo2(jp("query", js("project")), jp("limit", js("1"))))
            val response = handle_tool_call("1", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

    context "read_note":
        it "returns note metadata":
            val db = setup_test_db()
            val body = make_tool_request("2", "read_note", jo1(jp("path", js("alpha.md"))))
            val response = handle_tool_call("2", body, db, "")
            expect(response).to_contain("alpha.md")
            close_index_db(db)

        it "returns error for missing path param":
            val db = setup_test_db()
            val body = make_tool_request("2", "read_note", jo1(jp("dummy", js("x"))))
            val response = handle_tool_call("2", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

    context "search_by_tag":
        it "finds notes tagged with project":
            val db = setup_test_db()
            val body = make_tool_request("3", "search_by_tag", jo1(jp("tag", js("project"))))
            val response = handle_tool_call("3", body, db, "")
            expect(response).to_contain("Alpha")
            close_index_db(db)

        it "returns error for missing tag param":
            val db = setup_test_db()
            val body = make_tool_request("3", "search_by_tag", jo1(jp("dummy", js("x"))))
            val response = handle_tool_call("3", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

        it "finds notes tagged with reference":
            val db = setup_test_db()
            val body = make_tool_request("3", "search_by_tag", jo1(jp("tag", js("reference"))))
            val response = handle_tool_call("3", body, db, "")
            expect(response).to_contain("Beta")
            close_index_db(db)

    context "find_backlinks":
        it "finds notes linking to beta":
            val db = setup_test_db()
            val body = make_tool_request("4", "find_backlinks", jo1(jp("note_path", js("beta.md"))))
            val response = handle_tool_call("4", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

        it "returns error for missing note_path":
            val db = setup_test_db()
            val body = make_tool_request("4", "find_backlinks", jo1(jp("dummy", js("x"))))
            val response = handle_tool_call("4", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

# ============================================================================
# Test Group 6: Tool Dispatch — Phase 2 Graph + Ranking
# ============================================================================

describe "Tool Dispatch Graph":
    """Tests for Phase 2 tool dispatch: forward links, related, authority, graph walk"""

    context "find_forward_links":
        it "finds links from alpha":
            val db = setup_test_db()
            val body = make_tool_request("5", "find_forward_links", jo1(jp("note_path", js("alpha.md"))))
            val response = handle_tool_call("5", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

        it "returns error for missing note_path":
            val db = setup_test_db()
            val body = make_tool_request("5", "find_forward_links", jo1(jp("dummy", js("x"))))
            val response = handle_tool_call("5", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

    context "find_related":
        it "finds notes related to alpha":
            val db = setup_test_db()
            val body = make_tool_request("6", "find_related", jo1(jp("note_path", js("alpha.md"))))
            val response = handle_tool_call("6", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

    context "find_authoritative_docs":
        it "finds authoritative docs about search":
            val db = setup_test_db()
            val body = make_tool_request("7", "find_authoritative_docs", jo2(jp("query", js("search")), jp("limit", js("5"))))
            val response = handle_tool_call("7", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

        it "uses default limit when not specified":
            val db = setup_test_db()
            val body = make_tool_request("7", "find_authoritative_docs", jo1(jp("query", js("project"))))
            val response = handle_tool_call("7", body, db, "")
            expect(response).to_contain("result")
            close_index_db(db)

    context "graph_walk":
        it "walks graph from alpha":
            val db = setup_test_db()
            val body = make_tool_request("8", "graph_walk", jo2(jp("seed", js("alpha.md")), jp("hops", js("2"))))
            val response = handle_tool_call("8", body, db, "")
            expect(response).to_contain("nodes")
            close_index_db(db)

        it "returns error for missing seed":
            val db = setup_test_db()
            val body = make_tool_request("8", "graph_walk", jo1(jp("hops", js("2"))))
            val response = handle_tool_call("8", body, db, "")
            expect(response).to_contain("Missing required parameter")
            close_index_db(db)

        it "clamps hops to max 5":
            val db = setup_test_db()
            val body = make_tool_request("8", "graph_walk", jo2(jp("seed", js("alpha.md")), jp("hops", js("100"))))
            val response = handle_tool_call("8", body, db, "")
            # Should not error — hops clamped to 5
            expect(response).to_contain("nodes")
            close_index_db(db)

        it "uses default hops when not specified":
            val db = setup_test_db()
            val body = make_tool_request("8", "graph_walk", jo1(jp("seed", js("alpha.md"))))
            val response = handle_tool_call("8", body, db, "")
            expect(response).to_contain("nodes")
            close_index_db(db)

