# Unit tests for indexer module

use src.core.indexer.{IndexDb, open_index_memory, close_index_db, create_schema, index_note, remove_note, is_stale, note_count, link_count, task_count, get_note_by_path}

describe "Indexer":
    """Tests for in-memory indexing and CRUD operations"""

    context "schema creation":
        """Creating the in-memory database"""

        it "creates schema successfully":
            val db = open_index_memory()
            val ok = create_schema(db)
            expect(ok).to_equal(true)
            close_index_db(db)

        it "starts with zero notes":
            val db = open_index_memory()
            create_schema(db)
            expect(note_count(db)).to_equal(0)
            close_index_db(db)

    context "indexing notes":
        """Inserting and querying note data"""

        it "indexes a note with frontmatter":
            val db = open_index_memory()
            create_schema(db)
            val content = "---\ntitle: Test Note\ntags: [test, unit]\n---\n\n# Test Note\n\nSome content."
            val note_id = index_note(db, "/vault/test.md", "test.md", content, 1000)
            expect(note_id).to_be_greater_than(0)
            expect(note_count(db)).to_equal(1)
            close_index_db(db)

        it "stores note title":
            val db = open_index_memory()
            create_schema(db)
            val content = "---\ntitle: My Title\n---\n\n# My Title"
            index_note(db, "/vault/test.md", "test.md", content, 1000)
            val note = get_note_by_path(db, "test.md")
            expect(note.title).to_equal("My Title")
            close_index_db(db)

        it "indexes wikilinks":
            val db = open_index_memory()
            create_schema(db)
            val content = "# Test\n\nSee [[other-note]] and [[another]]."
            index_note(db, "/vault/test.md", "test.md", content, 1000)
            expect(link_count(db)).to_equal(2)
            close_index_db(db)

        it "indexes tasks":
            val db = open_index_memory()
            create_schema(db)
            val content = "# Tasks\n\n- [ ] Open task\n- [x] Done task"
            index_note(db, "/vault/test.md", "test.md", content, 1000)
            expect(task_count(db)).to_equal(2)
            close_index_db(db)

        it "stores tags from frontmatter and inline":
            val db = open_index_memory()
            create_schema(db)
            val content = "---\ntags: [project]\n---\n\n# Test\n\nContent with #inline tag"
            index_note(db, "/vault/test.md", "test.md", content, 1000)
            val note = get_note_by_path(db, "test.md")
            expect(note.tags).to_contain("project")
            expect(note.tags).to_contain("inline")
            close_index_db(db)

    context "removing notes":
        """Deleting notes and cascading"""

        it "removes a note and its dependents":
            val db = open_index_memory()
            create_schema(db)
            val content = "# Test\n\n[[link]] and - [ ] task"
            index_note(db, "/vault/test.md", "test.md", content, 1000)
            expect(note_count(db)).to_equal(1)
            remove_note(db, "test.md")
            expect(note_count(db)).to_equal(0)
            expect(link_count(db)).to_equal(0)
            expect(task_count(db)).to_equal(0)
            close_index_db(db)

    context "staleness check":
        """Checking if re-index is needed"""

        it "detects stale notes":
            val db = open_index_memory()
            create_schema(db)
            val content = "# Test"
            index_note(db, "/vault/test.md", "test.md", content, 1000)
            expect(is_stale(db, "test.md", 2000)).to_equal(true)
            expect(is_stale(db, "test.md", 1000)).to_equal(false)
            close_index_db(db)

        it "treats missing notes as stale":
            val db = open_index_memory()
            create_schema(db)
            expect(is_stale(db, "nonexistent.md", 1000)).to_equal(true)
            close_index_db(db)
